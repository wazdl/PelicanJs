    "api",
    "pelican-api",
    "javascript",
    "js",
    "nodejs",
    "typescript"
  ],
  "dependencies": {
    "axios": "^1.7.9"
  },
   "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "bugs": {
