  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "require": "./dist/index.js",
    "import": "./dist/index.mjs",
    "default": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=14.16"
  },
  "scripts": {
    "build": "tsc",
    "prepublish": "npm run build",
    "test": "Just a test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wazdl/pelicanjs.git"
  },
  "keywords": [
    "pelican",
    "panel",
    "hosting",
    "game-server",
    "discord-bot",
